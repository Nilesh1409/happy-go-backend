            "description": "Get detailed information about a specific hotel booking"
          }
        },
        {
          "name": "Update Hotel Booking Details",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
