            "url": {
              "raw": "{{BASE_URL}}/bookings/:bookingId",
              "host": ["{{BASE_URL}}"],
              "path": ["bookings", ":bookingId"],
              "variable": [
                {
                  "key": "bookingId",
                  "value": "booking_id_here",
                  "description": "Hotel booking ID"
                }
              ]
