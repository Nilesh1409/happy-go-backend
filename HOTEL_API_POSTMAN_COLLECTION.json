            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingType\": \"hotel\",\n  \"hotelId\": \"hotel_id_here\",\n  \"roomType\": \"Double Bed\",\n  \"startDate\": \"2025-05-01\",\n  \"endDate\": \"2025-05-03\",\n  \"numberOfPeople\": 2,\n  \"priceDetails\": {\n    \"basePrice\": 2400,\n    \"subtotal\": 2400,\n    \"bulkDiscount\": {\n      \"amount\": 0,\n      \"percentage\": 0\n    },\n    \"surgeMultiplier\": 1,\n    \"extraCharges\": 0,\n    \"helmetCharges\": 0,\n    \"taxes\": 120,\n    \"gstPercentage\": 5,\n    \"discount\": 0,\n    \"totalAmount\": 2520\n  },\n  \"hotelDetails\": {\n    \"roomOptions\": {\n      \"bedOnly\": {\n        \"quantity\": 0,\n        \"pricePerUnit\": 0\n      },\n      \"bedAndBreakfast\": {\n        \"quantity\": 1,\n        \"pricePerUnit\": 1200\n      },\n      \"bedBreakfastAndDinner\": {\n        \"quantity\": 0,\n        \"pricePerUnit\": 0\n      }\n    },\n    \"checkInTime\": \"14:00\"\n  },\n  \"guestDetails\": {\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"mobile\": \"9876543210\"\n  },\n  \"specialRequests\": \"Late check-in requested\",\n  \"couponCode\": \"\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/bookings",
              "host": ["{{BASE_URL}}"],
              "path": ["bookings"]
            },
            "description": "Create a new hotel booking"
          }
        },
