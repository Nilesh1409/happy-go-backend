            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkInTime\": \"15:30\",\n  \"specialRequests\": \"Updated: Need extra towels and early breakfast\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/bookings/:bookingId/hotel-details",
              "host": ["{{BASE_URL}}"],
              "path": ["bookings", ":bookingId", "hotel-details"],
              "variable": [
                {
                  "key": "bookingId",
                  "value": "booking_id_here",
                  "description": "Hotel booking ID"
                }
              ]
            },
            "description": "Update hotel booking details like check-in time and special requests"
          }
        },
        {
          "name": "Cancel Hotel Booking",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\",\n  \"cancellationReason\": \"Change of travel plans\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/bookings/:bookingId/status",
              "host": ["{{BASE_URL}}"],
              "path": ["bookings", ":bookingId", "status"],
              "variable": [
                {
                  "key": "bookingId",
                  "value": "booking_id_here",
                  "description": "Hotel booking ID"
                }
              ]
            },
            "description": "Cancel a hotel booking"
          }
        }
      ]
    },
