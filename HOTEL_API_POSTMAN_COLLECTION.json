{
  "info": {
    "name": "Hotel/Hostel API Collection",
    "description": "Complete collection of Hotel/Hostel API endpoints for HappyGo Backend",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "USER_TOKEN",
      "value": "your_user_jwt_token_here",
      "type": "string"
    },
    {
      "key": "ADMIN_TOKEN",
      "value": "your_admin_jwt_token_here",
      "type": "string"
    },
    {
      "key": "EMPLOYEE_TOKEN",
      "value": "your_employee_jwt_token_here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Hotel Management",
      "item": [
        {
          "name": "Get All Hotels",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/hotels?limit=10&page=1&sort=-createdAt",
              "host": ["{{BASE_URL}}"],
              "path": ["hotels"],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of hotels per page"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "sort",
                  "value": "-createdAt",
                  "description": "Sort by field (prefix with - for descending)"
                },
                {
                  "key": "search",
                  "value": "Chikkamagaluru",
                  "disabled": true,
                  "description": "Search by name or location"
                }
              ]
            },
            "description": "Get all hotels with pagination, sorting, and search functionality"
          }
        },
        {
          "name": "Get Single Hotel",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/hotels/:hotelId",
              "host": ["{{BASE_URL}}"],
              "path": ["hotels", ":hotelId"],
              "variable": [
                {
                  "key": "hotelId",
                  "value": "hotel_id_here",
                  "description": "Hotel ID"
                }
              ]
            },
            "description": "Get detailed information about a specific hotel"
          }
        },
        {
          "name": "Get Available Hotels",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/hotels/available?checkIn=2025-05-01&checkOut=2025-05-03&people=2",
              "host": ["{{BASE_URL}}"],
              "path": ["hotels", "available"],
              "query": [
                {
                  "key": "checkIn",
                  "value": "2025-05-01",
                  "description": "Check-in date (YYYY-MM-DD)"
                },
                {
                  "key": "checkOut",
                  "value": "2025-05-03",
                  "description": "Check-out date (YYYY-MM-DD)"
                },
                {
                  "key": "people",
                  "value": "2",
                  "description": "Number of people"
                }
              ]
            },
            "description": "Get hotels available for booking in a specific time period with room availability"
          }
        },
        {
          "name": "Create Hotel (Admin Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mountain View Hostel\",\n  \"description\": \"A cozy hostel with beautiful mountain views and modern amenities\",\n  \"location\": \"Chikkamagaluru\",\n  \"address\": \"123 Mountain Road, Chikkamagaluru, Karnataka 577101\",\n  \"images\": [\n    \"https://example.com/hotel1.jpg\",\n    \"https://example.com/hotel2.jpg\"\n  ],\n  \"amenities\": [\n    {\n      \"name\": \"Free WiFi\",\n      \"icon\": \"wifi\"\n    },\n    {\n      \"name\": \"Parking\",\n      \"icon\": \"parking\"\n    },\n    {\n      \"name\": \"24/7 Reception\",\n      \"icon\": \"reception\"\n    }\n  ],\n  \"rooms\": [\n    {\n      \"type\": \"Single Bed\",\n      \"description\": \"Comfortable single bed room with shared bathroom\",\n      \"images\": [\"https://example.com/single-room.jpg\"],\n      \"capacity\": 1,\n      \"priceOptions\": {\n        \"bedOnly\": {\n          \"basePrice\": 800,\n          \"discountedPrice\": 700\n        },\n        \"bedAndBreakfast\": {\n          \"basePrice\": 1000,\n          \"discountedPrice\": 900\n        },\n        \"bedBreakfastAndDinner\": {\n          \"basePrice\": 1400,\n          \"discountedPrice\": 1200\n        }\n      },\n      \"amenities\": [\"AC\", \"WiFi\", \"Towels\"],\n      \"totalRooms\": 10,\n      \"availableRooms\": 10\n    },\n    {\n      \"type\": \"Double Bed\",\n      \"description\": \"Spacious double bed room with private bathroom\",\n      \"images\": [\"https://example.com/double-room.jpg\"],\n      \"capacity\": 2,\n      \"priceOptions\": {\n        \"bedOnly\": {\n          \"basePrice\": 1200,\n          \"discountedPrice\": 1000\n        },\n        \"bedAndBreakfast\": {\n          \"basePrice\": 1500,\n          \"discountedPrice\": 1300\n        },\n        \"bedBreakfastAndDinner\": {\n          \"basePrice\": 2000,\n          \"discountedPrice\": 1800\n        }\n      },\n      \"amenities\": [\"AC\", \"WiFi\", \"Private Bathroom\", \"TV\"],\n      \"totalRooms\": 5,\n      \"availableRooms\": 5\n    }\n  ],\n  \"guidelines\": [\n    \"Check-in time: 2:00 PM\",\n    \"Check-out time: 11:00 AM\",\n    \"No smoking inside rooms\",\n    \"Quiet hours: 10:00 PM - 7:00 AM\"\n  ],\n  \"checkInGuidelines\": [\n    \"Valid ID required for check-in\",\n    \"Advance payment required\",\n    \"Guest registration mandatory\"\n  ],\n  \"cancellationPolicies\": [\n    \"Free cancellation up to 24 hours before check-in\",\n    \"50% refund for cancellations within 24 hours\",\n    \"No refund for no-shows\"\n  ],\n  \"ratings\": 4.2,\n  \"numReviews\": 45,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/hotels",
              "host": ["{{BASE_URL}}"],
              "path": ["hotels"]
            },
            "description": "Create a new hotel (Admin access required)"
          }
        },
        {
          "name": "Update Hotel (Admin Only)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Mountain View Hostel\",\n  \"description\": \"An updated cozy hostel with beautiful mountain views\",\n  \"ratings\": 4.5,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/hotels/:hotelId",
              "host": ["{{BASE_URL}}"],
              "path": ["hotels", ":hotelId"],
              "variable": [
                {
                  "key": "hotelId",
                  "value": "hotel_id_here",
                  "description": "Hotel ID to update"
                }
              ]
            },
            "description": "Update hotel details (Admin access required)"
          }
        },
        {
          "name": "Delete Hotel (Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/hotels/:hotelId",
              "host": ["{{BASE_URL}}"],
              "path": ["hotels", ":hotelId"],
              "variable": [
                {
                  "key": "hotelId",
                  "value": "hotel_id_here",
                  "description": "Hotel ID to delete"
                }
              ]
            },
            "description": "Delete a hotel (Admin access required)"
          }
        }
      ]
    },
    {
      "name": "Hotel Bookings",
      "item": [
        {
          "name": "Create Hotel Booking",
          "request": {
            "method": "POST",
